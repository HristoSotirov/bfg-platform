{
  "name": "bfg-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run generate:api && ng serve",
    "build": "npm run generate:api && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate:api": "openapi-generator-cli generate -i ../backend/src/main/resources/static/openapi/openapi.yaml -g typescript-angular -o src/app/core/services/api --skip-validate-spec --additional-properties=ngVersion=17.3.0,providedInRoot=true,serviceSuffix=Service"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "17.3.0",
    "@angular/common": "17.3.0",
    "@angular/compiler": "17.3.0",
    "@angular/core": "17.3.0",
    "@angular/forms": "17.3.0",
    "@angular/platform-browser": "17.3.0",
    "@angular/platform-browser-dynamic": "17.3.0",
    "@angular/router": "17.3.0",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "ngx-image-cropper": "9.1.6",
    "rxjs": "7.8.1",
    "tslib": "2.3.0",
    "xlsx": "0.18.5",
    "zone.js": "0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "17.3.0",
    "@angular/cli": "17.3.0",
    "@angular/compiler-cli": "17.3.0",
    "@openapitools/openapi-generator-cli": "2.13.0",
    "@types/jasmine": "5.1.0",
    "autoprefixer": "10.4.19",
    "jasmine-core": "5.1.0",
    "karma": "6.4.0",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.0",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.1",
    "typescript": "5.4.2"
  }
}
