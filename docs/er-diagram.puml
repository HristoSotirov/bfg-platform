club_coaches }|--|| clubs : club_id
accreditations }|--|| athletes : athlete_id
accreditations }|--|| clubs : club_id
photos }|--|| athletes : athlete_id
photos }|--|| clubs : uploaded_by

' Definitions
comp_groups ||--o| comp_groups : transfer_group_id
disciplines }o--|| comp_groups : competition_group_id

' Discipline groups
disc_group_items }|--|| disc_groups : discipline_group_id
disc_group_items }|--|| disciplines : discipline_id

' Scoring
scoring_rules }|--|| scoring_schemes : scoring_scheme_id

' Qualification
qual_stages }|--|| qual_schemes : scheme_id
qual_rules }|--|| qual_schemes : scheme_id
qual_rules }|--|| qual_stages : source_stage_id
qual_rules }|--|| qual_stages : destination_stage_id

' Templates
comp_templates }o--o| scoring_schemes : scoring_scheme_id
stage_templates }|--|| comp_templates : competition_template_id
stage_templates }o--o| qual_schemes : qualification_scheme_id
stage_templates }o--o| disc_groups : discipline_group_id
tt_templates }|--|| comp_templates : competition_template_id
tt_templates }o--o| stage_templates : stage_template_id

' Competitions
competitions }o--o| scoring_schemes : scoring_scheme_id
comp_stages }|--|| competitions : competition_id
comp_stages }o--o| qual_schemes : qualification_scheme_id
comp_stages }o--o| disc_groups : discipline_group_id

' Entries & Participation
entries }|--|| competitions : competition_id
entries }|--|| comp_stages : stage_id
entries }|--|| clubs : club_id
entries }|--|| disciplines : discipline_id
crew }|--|| entries : entry_id
crew }|--|| athletes : athlete_id
events }|--|| competitions : competition_id
events }|--|| comp_stages : stage_id
events }|--|| disciplines : discipline_id
participations }|--|| events : competition_event_id
participations }|--|| entries : entry_id
standings }|--|| competitions : competition_id
standings }|--|| comp_stages : stage_id
standings }|--|| disciplines : discipline_id
standings }|--|| entries : entry_id

' Weight measurements
weights }|--|| athletes : athlete_id

@enduml
